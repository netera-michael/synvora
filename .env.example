# Database — use connection pooler URL for the app, direct URL for migrations
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/synvora?sslmode=require"
DATABASE_URL_DIRECT="postgresql://user:password@host.neon.tech/synvora?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-random-32-plus-char-string"
NEXTAUTH_URL="https://your-domain.vercel.app"

# Encryption — must be exactly 32 characters
ENCRYPTION_KEY="32-character-random-string-here!"

# Shopify webhook HMAC verification
SHOPIFY_WEBHOOK_SECRET="your-shopify-webhook-secret-here"

# Sentry (optional — remove if not using Sentry)
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="javascript-nextjs"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
